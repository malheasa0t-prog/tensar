# Public Supabase variables (safe for browser usage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase key for secure API operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Serva-S Provider API for order fulfillment
PROVIDER_API_BASE_URL=https://serva-s.com/api/v1
PROVIDER_API_KEY=your-serva-api-key
PROVIDER_API_TIMEOUT_MS=15000

# Required: protect /api/orders/sync with a shared secret header x-cron-secret
CRON_SECRET=replace-with-strong-random-string

# Hide the internal admin panel until you are ready to launch it
NEXT_PUBLIC_ENABLE_ADMIN_PANEL=false

# Legacy admin shell runtime config
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
ENABLE_LEGACY_ADMIN_WRITE=false
ADMIN_DEV_BYPASS=false

# Optional analytics providers
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=123456789012345
NEXT_PUBLIC_HOTJAR_ID=1234567
NEXT_PUBLIC_HOTJAR_VERSION=6
