# Public Supabase variables (safe for browser usage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase key for secure API operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional provider API integration for order sync
PROVIDER_API_BASE_URL=https://provider.example.com/api/v2
PROVIDER_API_KEY=your-provider-api-key
PROVIDER_API_TIMEOUT_MS=10000

# Optional: protect /api/orders/sync with a shared secret header x-cron-secret
CRON_SECRET=replace-with-strong-random-string

# Hide the internal admin panel until you are ready to launch it
NEXT_PUBLIC_ENABLE_ADMIN_PANEL=false
