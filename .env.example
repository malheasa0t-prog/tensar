# Public Supabase variables (safe for browser usage)
NEXT_PUBLIC_SITE_URL=https://tensr.systems
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: show only OAuth providers that are fully configured in Supabase Auth and the provider console.
# Example: google or google,facebook
NEXT_PUBLIC_AUTH_SOCIAL_PROVIDERS=google
IMAGE_PROXY_ALLOWED_HOSTS=placehold.co,serva-s.com

# Server-only Supabase key for secure API operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Serva-S provider API for importing services and syncing provider orders
PROVIDER_API_KEY=your-serva-api-key
PROVIDER_API_BASE_URL=https://serva-s.com/api/v1
PROVIDER_API_TIMEOUT_MS=15000

# AI chatbot provider
GROQ_API_KEY=your-groq-api-key

# Required: protect /api/orders/sync with a shared secret header x-cron-secret
CRON_SECRET=replace-with-strong-random-string

# Hide the internal admin panel until you are ready to launch it
NEXT_PUBLIC_ENABLE_ADMIN_PANEL=false

# Legacy admin shell runtime config
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
ENABLE_LEGACY_ADMIN_WRITE=false
# Keep disabled in Cloudflare production. Local admin bypass is now localhost-only and audited.
ADMIN_DEV_BYPASS=false
# Optional Cloudflare Access gate for the legacy admin shell.
# public: shell stays visible, cf-access: require Cloudflare Access identity, deny: always hide.
ADMIN_SHELL_ACCESS_MODE=public
# Optional allowlists when ADMIN_SHELL_ACCESS_MODE=cf-access.
ADMIN_SHELL_ALLOWED_EMAILS=admin@example.com
ADMIN_SHELL_ALLOWED_DOMAINS=example.com

# Optional analytics providers
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=123456789012345
NEXT_PUBLIC_HOTJAR_ID=1234567
NEXT_PUBLIC_HOTJAR_VERSION=6
